# --- Lightfield CRM API ---
# Create an API key in Lightfield settings (admin only): https://docs.lightfield.app/using-the-api/api-keys/
# Required scopes: accounts/contacts/opportunities/tasks/notes/meetings/emails/lists read,
# plus create+update for accounts, contacts, opportunities, tasks, notes, lists.
# Leave empty to run the portal against built-in sample data (mock mode).
LIGHTFIELD_API_KEY=sk_lf_...

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Base URL of the app (only needed when deploying behind a proxy)
# AUTH_URL=http://localhost:3000

# --- Database (Turso / libSQL) ---
# Production: create a database at https://turso.tech and paste its values here.
#   turso db create pulsar && turso db show pulsar --url && turso db tokens create pulsar
# Leave both empty to use a local SQLite file at ./data/app.db (default for local dev).
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=
